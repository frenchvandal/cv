---
import { getRelativeLocaleUrl } from 'astro:i18n';
import {
  LANG_LABEL,
  LANGS,
  type Lang,
  PROFILE,
  translations,
} from '../data/translations.ts';
import HeroName from './HeroName.tsx';
import SectionHeading from './SectionHeading.astro';
import type { LangLink, NavItem } from './SiteHeader.tsx';
import SiteHeader from './SiteHeader.tsx';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang];

const navItems: NavItem[] = [
  { id: 'about', label: t.nav.about },
  { id: 'experience', label: t.nav.experience },
  { id: 'education', label: t.nav.education },
  { id: 'skills', label: t.nav.skills },
  { id: 'hobbies', label: t.nav.hobbies },
  { id: 'contact', label: t.nav.contact },
];

const langLinks: LangLink[] = LANGS.map((code) => ({
  code,
  label: LANG_LABEL[code],
  href: getRelativeLocaleUrl(code, ''),
  current: code === lang,
}));

const homeHref = getRelativeLocaleUrl(lang, '');

const stats = [
  { value: '8+', label: t.about.stats.years },
  { value: '5.66', label: t.about.stats.gpa },
  { value: '4', label: t.about.stats.languages },
  { value: '152', label: t.about.stats.ects },
];

const studentJobs = [t.experience.galexis, t.experience.uber, t.experience.gfk];

const bachelor = t.education.bachelor;
const thesisRows = [
  { key: bachelor.methodology, value: bachelor.methodologyValue },
  { key: bachelor.dataSources, value: bachelor.dataSourcesValue },
  { key: bachelor.tools, value: bachelor.toolsValue },
  { key: bachelor.focus, value: bachelor.focusValue },
];

const skillGroups = [
  t.skills.data,
  t.skills.econometrics,
  t.skills.it,
  t.skills.finance,
  t.skills.economics,
  t.skills.accounting,
  t.skills.programming,
  t.skills.soft,
];

const languages = [
  { flag: '🇫🇷', ...t.skills.languages.french },
  { flag: '🇵🇹', ...t.skills.languages.portuguese },
  { flag: '🇬🇧', ...t.skills.languages.english },
  { flag: '🇨🇳', ...t.skills.languages.chinese },
];

interface Hobby {
  icon: string;
  title: string;
  desc: string;
  link?: string;
  href?: string;
}
const hobbies: Hobby[] = [
  {
    icon: '🎸',
    title: t.hobbies.music.title,
    desc: t.hobbies.music.desc,
    link: t.hobbies.music.link,
    href: PROFILE.spotifyUrl,
  },
  { icon: '🎮', title: t.hobbies.gaming.title, desc: t.hobbies.gaming.desc },
  { icon: '✈️', title: t.hobbies.travel.title, desc: t.hobbies.travel.desc },
  { icon: '🚴', title: t.hobbies.cycling.title, desc: t.hobbies.cycling.desc },
  { icon: '🌏', title: t.hobbies.language.title, desc: t.hobbies.language.desc },
];
---

<SiteHeader
  client:load
  logo={PROFILE.logo}
  homeHref={homeHref}
  navItems={navItems}
  langLinks={langLinks}
  labels={{ primaryNav: t.ui.primaryNav, languageNav: t.ui.languageNav, theme: t.ui.theme }}
/>

<main id="main">
  {/* Hero */}
  <section class="hero">
    <div class="hero__inner container">
      <p class="hero__greeting">{t.hero.greeting}</p>
      <HeroName client:load lines={PROFILE.nameLines} />
      <p class="hero__title">{t.hero.title}</p>
      <p class="hero__location">{t.hero.location}</p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="#contact">{t.hero.ctaPrimary}</a>
        <a class="btn btn--secondary" href="#about">{t.hero.ctaSecondary}</a>
      </div>
    </div>
    <a class="hero__scroll" href="#about" aria-label={t.hero.scrollHint}>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M6 9l6 6 6-6"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>
  </section>

  {/* About */}
  <section id="about" class="section">
    <div class="container">
      <SectionHeading eyebrow={t.about.tag} title={t.about.title} />
      <div class="about">
        <div class="about__text">
          <p>{t.about.p1}</p>
          <p>{t.about.p2}</p>
          <p>{t.about.p3}</p>
        </div>
        <dl class="stats">
          {stats.map((stat) => (
            <div class="stat card">
              <dt class="stat__label">{stat.label}</dt>
              <dd class="stat__value">{stat.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </section>

  {/* Experience */}
  <section id="experience" class="section section--subtle">
    <div class="container">
      <SectionHeading eyebrow={t.experience.tag} title={t.experience.title} />
      <article class="card exp">
        <header class="exp__head">
          <div>
            <h3 class="exp__role">{t.experience.chuv.title}</h3>
            <p class="exp__org">{t.experience.chuv.company}</p>
          </div>
          <span class="badge">{t.experience.chuv.date}</span>
        </header>
        <ul class="exp__list">
          {t.experience.chuv.items.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <p class="divider"><span>{t.experience.studentJobsTitle}</span></p>

      <div class="jobs">
        {studentJobs.map((job) => (
          <article class="card job">
            <header class="job__head">
              <div>
                <h4 class="job__role">{job.title}</h4>
                <p class="job__org">{job.company}</p>
              </div>
              <span class="job__date">{job.date}</span>
            </header>
            <p class="job__desc">{job.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* Education */}
  <section id="education" class="section">
    <div class="container">
      <SectionHeading eyebrow={t.education.tag} title={t.education.title} />
      <ol class="timeline">
        <li class="timeline__item">
          <article class="card timeline__body">
            <header class="timeline__head">
              <h3 class="timeline__title">{bachelor.title}</h3>
              <span class="timeline__date">{bachelor.date}</span>
            </header>
            <p class="timeline__subtitle">{bachelor.subtitle}</p>
            <ul class="timeline__list">
              {bachelor.courses.map((course) => <li>{course}</li>)}
            </ul>
            <div class="thesis">
              <p class="thesis__label">{bachelor.thesisTitle}</p>
              <p class="thesis__title">{bachelor.thesis}</p>
              <p class="thesis__subject"><em>{bachelor.thesisSubject}</em></p>
              <dl class="thesis__grid">
                {thesisRows.map((row) => (
                  <div class="thesis__row">
                    <dt class="thesis__key">{row.key}</dt>
                    <dd class="thesis__value">{row.value}</dd>
                  </div>
                ))}
              </dl>
            </div>
          </article>
        </li>

        <li class="timeline__item">
          <article class="card timeline__body">
            <header class="timeline__head">
              <h3 class="timeline__title">{t.education.china.title}</h3>
              <span class="timeline__date">{t.education.china.date}</span>
            </header>
            <p class="timeline__subtitle">{t.education.china.subtitle}</p>
            <ul class="timeline__list">
              <li>{t.education.china.csc}</li>
              <li>{t.education.china.intensive} — {t.education.china.gpa} {t.education.china.gpaDesc}</li>
              <li>{t.education.china.immersion}</li>
              <li>{t.education.china.adaptability}</li>
            </ul>
          </article>
        </li>

        <li class="timeline__item">
          <article class="card timeline__body">
            <header class="timeline__head">
              <h3 class="timeline__title">{t.education.cfc.title}</h3>
              <span class="timeline__date">{t.education.cfc.date}</span>
            </header>
            <p class="timeline__subtitle">{t.education.cfc.subtitle}</p>
            <p class="timeline__desc">{t.education.cfc.desc}</p>
          </article>
        </li>

        <li class="timeline__item">
          <article class="card timeline__body">
            <header class="timeline__head">
              <h3 class="timeline__title">{t.education.epfl.title}</h3>
              <span class="timeline__date">{t.education.epfl.date}</span>
            </header>
            <p class="timeline__subtitle">{t.education.epfl.subtitle}</p>
            <p class="timeline__desc">{t.education.epfl.desc}</p>
          </article>
        </li>
      </ol>
    </div>
  </section>

  {/* Skills */}
  <section id="skills" class="section section--subtle">
    <div class="container">
      <SectionHeading eyebrow={t.skills.tag} title={t.skills.title} />
      <div class="skills">
        {skillGroups.map((group) => (
          <article class="card skill-group">
            <h3 class="skill-group__title">{group.title}</h3>
            <ul class="tags">
              {group.tags.map((tag) => <li class="tag">{tag}</li>)}
            </ul>
          </article>
        ))}
      </div>

      <div class="card langs-card">
        <h3 class="langs-card__title">{t.skills.languages.title}</h3>
        <ul class="langs">
          {languages.map((language) => (
            <li class="lang-item">
              <span class="lang-item__flag" aria-hidden="true">{language.flag}</span>
              <span class="lang-item__name">{language.name}</span>
              <span class="lang-item__level">{language.level}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {/* Hobbies */}
  <section id="hobbies" class="section">
    <div class="container">
      <SectionHeading eyebrow={t.hobbies.tag} title={t.hobbies.title} />
      <ul class="hobbies">
        {hobbies.map((hobby) => (
          <li class="card hobby">
            <span class="hobby__icon" aria-hidden="true">{hobby.icon}</span>
            <h3 class="hobby__title">{hobby.title}</h3>
            <p class="hobby__desc">{hobby.desc}</p>
            {hobby.href && hobby.link && (
              <a class="hobby__link" href={hobby.href} target="_blank" rel="noopener noreferrer">
                {hobby.link}
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M3.75 2h3.5a.75.75 0 0 1 0 1.5h-3.5a.25.25 0 0 0-.25.25v8.5c0 .138.112.25.25.25h8.5a.25.25 0 0 0 .25-.25v-3.5a.75.75 0 0 1 1.5 0v3.5A1.75 1.75 0 0 1 12.25 14h-8.5A1.75 1.75 0 0 1 2 12.25v-8.5C2 2.784 2.784 2 3.75 2Zm6.854-1h4.146a.25.25 0 0 1 .25.25v4.146a.25.25 0 0 1-.427.177L13.03 4.03 9.28 7.78a.751.751 0 0 1-1.06-1.06l3.75-3.75-1.543-1.543A.25.25 0 0 1 10.604 1Z"></path>
                </svg>
              </a>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* Contact */}
  <section id="contact" class="section section--subtle">
    <div class="container">
      <SectionHeading eyebrow={t.contact.tag} title={t.contact.title} />
      <div class="contact card">
        <p class="contact__intro">{t.contact.intro}</p>
        <ul class="contact__list">
          <li class="contact__item">
            <span class="contact__icon" aria-hidden="true">📍</span>
            <span class="contact__meta">
              <span class="contact__label">{t.contact.locationLabel}</span>
              <span class="contact__value">{PROFILE.location}</span>
            </span>
          </li>
          <li class="contact__item">
            <span class="contact__icon" aria-hidden="true">✉️</span>
            <span class="contact__meta">
              <span class="contact__label">{t.contact.emailLabel}</span>
              <a class="contact__value contact__link" href={`mailto:${PROFILE.email}`}>{PROFILE.email}</a>
            </span>
          </li>
        </ul>
      </div>
    </div>
  </section>
</main>

<footer class="footer">
  <p class="container">{t.contact.footer}</p>
</footer>
